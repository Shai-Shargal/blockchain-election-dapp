# ── Contract addresses (copy from deploy script output) ──────────────────────
VITE_ELECTION_ADDRESS=0xYOUR_ELECTION_CONTRACT_ADDRESS
VITE_BAL_TOKEN_ADDRESS=0xYOUR_BALTOKEN_ADDRESS

# ── Network ───────────────────────────────────────────────────────────────────
VITE_SEPOLIA_CHAIN_ID=11155111

# ── Admin wallet ──────────────────────────────────────────────────────────────
# Must match the deployer address used in deploy.ts (the Ownable owner)
VITE_ADMIN_ADDRESS=0xYOUR_DEPLOYER_ADDRESS

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# These are SERVER-SIDE only — the Vite dev proxy reads them from process.env
# NEVER use the VITE_ prefix for these keys (they would be bundled into the browser)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret
